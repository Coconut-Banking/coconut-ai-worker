GITHUB_TOKEN=
GITHUB_OWNER=Coconut-Banking
GITHUB_REPO=coconut
REPO_CLONE_URL=https://github.com/Coconut-Banking/coconut.git
REPO_DEFAULT_BRANCH=main

OPENAI_API_KEY=
OPENAI_MODEL_PLANNER=gpt-4o
OPENAI_MODEL_CODER=gpt-4o

WORKER_BASE_DIR=/tmp/coconut-ai-worker
RUNS_DIR=./runs
LOGS_DIR=./logs

MAX_TASKS_PER_RUN=1
MAX_FILES_CHANGED=5
TEST_MODE=true
DRY_RUN=true
KEEP_SANDBOX=true
DEBUG=true
OPEN_PR=false
